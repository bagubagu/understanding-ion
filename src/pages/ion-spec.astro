            </g>

            <!-- flow line -->
            <line x1="20" y1="305" x2="1107" y2="305" stroke="#7a6f5e" stroke-width="1" marker-end="url(#chev)"/>
            <text x="20" y="330" font-family="JetBrains Mono" font-size="9" fill="#7a6f5e">publish_catalog</text>
