---
import BaseLayout from '../layouts/BaseLayout.astro';
import { lastUpdated } from '../lib/last-updated.js';
import { docs } from '../lib/docs.js';
const updated = lastUpdated('public/ion-full.yaml');
const here = '/ion-spec/';

const title = "Reading ion-full.yaml — The ION Specification · ION Network";
const description = "A guided reading of ion-full.yaml: the single-file OpenAPI 3.1.1 specification that extends Beckn Protocol v2.0 into the Indonesia Open Network — its four layers, eight new endpoints, attribute packs, and the regulatory rules ONIX enforces.";

// ── L4: ION core attribute packs (cross-sector) ──────────────────────────
const corePacks = [
  { nm: 'IONParticipant', dn: 'Who is acting — role, subscriberId, NPWP/NIB/NIK, KTP, bank & insurer licences, plus the full Indonesian address hierarchy.', slot: 'Participant.participantAttributes' },
  { nm: 'IONBusinessIdentity', dn: 'A provider’s legal proof — NPWP, NIB (OSS), PKP status, legal entity type (PT/CV/UD/Koperasi…).', slot: 'Provider.providerAttributes' },
  { nm: 'PaymentDeclaration', dn: 'The authoritative payment rail per transaction — method, collectedBy, timing, gateway, and a oneOf of instrument detail.', slot: 'Settlement.settlementAttributes' },
  { nm: 'IONReconciliation', dn: 'Settlement basis, withholding, and the signed adjustment ledger (penalties, rebates, COD remittance).', slot: 'Settlement.settlementAttributes' },
  { nm: 'IONTaxDetail', dn: 'Tax regime (PPN / PPnBM / PPh), category (BKP/JKP), rate, and the eFaktur reference.', slot: 'Consideration (nested)' },
  { nm: 'IONAddressSubdivisions', dn: 'BPS province→kelurahan codes, RT/RW, landmark (patokan), 3T remote classification, last-mile accessibility flags.', slot: 'address / location detail' },
  { nm: 'IONProductCertifications', dn: 'Halal (MUI), BPOM registration, SNI, SP-PIRT food licence, age restrictions.', slot: 'product attributes' },
  { nm: 'IONRating', dn: 'Verified-purchase reviews — 1–5 scale, dimension sub-categories, media, seller response.', slot: 'RatingInput.target.targetAttributes' },
  { nm: 'IONSupportTicket', dn: 'Consumer complaint triage — category, severity, SLA clocks, escalation ladder.', slot: 'Support.channels[*]' },
  { nm: 'IONTicket', dn: 'Network-level dispute object carried in the /raise body — type, thread, resolution, penalty.', slot: '/raise message body' },
  { nm: 'IONCatalogLocalization', dn: 'Multilingual catalog text keyed by language (id / en / ms / zh …).', slot: 'catalog / item attributes' },
];

// ── L5: sector attribute packs ───────────────────────────────────────────
const tradePacks = ['TradeProvider', 'TradeOffer', 'TradeResource', 'TradeCommitment', 'TradeConsideration', 'TradeContract', 'TradePerformance'];
const logiPacks = ['LogisticsProvider', 'LogisticsOffer', 'LogisticsShipment', 'LogisticsCommitment', 'LogisticsConsideration', 'LogisticsContract', 'LogisticsPerformance', 'LogisticsTracking', 'LogisticsParticipantAddendum'];

// ── x-ion-conditional-rules: the five cross-schema rules ──────────────────
const rules = [
  { when: 'participant.role = DRIVER', then: 'driverLicenceCategory', on: 'LogisticsParticipantAddendum', why: 'a courier must declare which SIM class authorises their vehicle.' },
  { when: 'participant.role = DRIVER', then: 'driverLicenceNumber', on: 'LogisticsParticipantAddendum', why: 'identifies the human carrying the parcel (roro, freight, hyperlocal).' },
  { when: 'participant.role = CUSTOMS_BROKER', then: 'ppjkLicenceNumber', on: 'LogisticsParticipantAddendum', why: 'cross-border clearance requires a registered PPJK.' },
  { when: 'payment.paymentRail = COD', then: 'codAmount', on: 'TradeContract', why: 'cash-on-delivery must state the sum the courier collects.' },
  { when: 'identity.pkpStatus = PKP', then: 'fakturPajakReference', on: 'TradeContract', why: 'a PKP seller issuing a TAX_INVOICE owes a tax-invoice number.' },
];

// ── L5 trade pack — the seven schemas, grouped by transaction phase ───────
const tradePhases = [
  {
    badge: 'CATALOG', title: 'Catalog-time', why: 'written by BPP · returned in on_discover',
    packs: [
      { name: 'TradeProvider', slot: 'Provider.providerAttributes', set: 'publish_catalog', req: '9', fields: [
        'providerCategory — RESTAURANT | GROCERY | PHARMACY | FASHION | … (16+)',
        'invoicingModel — CENTRAL | PER_FULFILMENT_CENTRE',
        'kycLevel — BASIC | STANDARD | ENHANCED | ENTERPRISE',
        'storeStatus, operatingHours, holidayCalendar, kycValidUntil',
        'nibRegistered: boolean',
      ] },
      { name: 'TradeResource', slot: 'Resource.resourceAttributes', set: 'publish_catalog', req: 'none (open bag)', fields: [
        'resourceStructure — PLAIN | VARIANT | WITH_EXTRAS | COMPOSED | BUNDLE',
        'resourceTangibility — PHYSICAL | DIGITAL_VOUCHER | DIGITAL_TOP_UP | DIGITAL_SUBSCRIPTION',
        'variantMatrix, customisationGroups, menuCategory, preparationTime',
        'identity, physical, packaged, regulatory (sub-objects)',
      ] },
      { name: 'TradeOffer', slot: 'Offer.offerAttributes', set: 'publish_catalog', req: '11', fields: [
        'offerType — LIST_PRICE | DISCOUNT | BUNDLE | BUY_X_GET_Y | CASHBACK | FREE_DELIVERY',
        'priceModel — FIXED | DYNAMIC | TIERED',
        'returnable, availableOnCod: boolean · timeToShip · displayLanguage',
        'policy IRIs: cancellation, return, warranty, dispute, grievanceSla, paymentTerms',
      ] },
    ],
  },
  {
    badge: 'ORDER', title: 'Order-time', why: 'negotiated across select → init → confirm',
    packs: [
      { name: 'TradeCommitment', slot: 'Commitment.commitmentAttributes', set: 'select', req: '4', fields: [
        'lineId, resourceId, offerId: string',
        'quantity — { count: int≥1 } | { measure: { unit: GRAM|KILOGRAM|LITRE|…, value: ≥0 } }',
        'price — { value: string, currency: const IDR } · set by BPP at on_select',
        'customisationSelections (req for COMPOSED | WITH_EXTRAS) · specialInstructions: maxLength 500',
      ] },
      { name: 'TradeConsideration', slot: 'Consideration.considerationAttributes', set: 'on_select / on_init', req: '3', fields: [
        'breakupLineType — 29-value enum: ITEM, DELIVERY, TAX, TAX_PPNBM, …, PPH_WITHHOLDING, PPN_REMIT_PMSE',
        'ppnRate — number 0..1, required on TAX lines (PMK 131/2024)',
        'ppnbmRate — number 0..1, luxury goods',
        'discountType — PERCENT | FIXED · totalAmount: number · currency: const IDR',
      ] },
      { name: 'TradeContract', slot: 'Contract.contractAttributes', set: 'init / confirm', req: 'none — if/then + cross-schema', fields: [
        'invoicePreferences.invoiceType — RECEIPT | TAX_INVOICE | EINVOICE | SURAT_TAGIHAN | KOMERSIAL_INVOICE',
        'cancellationReasonCode — BUYER_REQUESTED | ITEM_UNAVAILABLE | … | FORCE_CANCEL_TAT_BREACH (8)',
        'codAmount (cross-schema: rail=COD) · fakturPajakReference (cross-schema: pkpStatus=PKP)',
        'inline: subscriptionPauseType=PAUSED_UNTIL_DATE ⇒ require subscriptionPauseUntil',
      ] },
    ],
  },
  {
    badge: 'FULFIL', title: 'Fulfilment-time', why: 'updated post-confirm via on_status / on_track',
    packs: [
      { name: 'TradePerformance', slot: 'Performance.performanceAttributes', set: 'on_status / on_track', req: '3', fields: [
        'performanceMode — DELIVERY | SELF_PICKUP | DINE_IN | CURBSIDE',
        'supportedPerformanceModes: array · sla (required)',
        'awbNumber, trackingUrl, realTimeGps, deliveryOtp, deliveryProofUrl',
        'ageVerificationRequired: boolean (+ method, evidence for restricted goods)',
      ] },
    ],
  },
];

// A sample TradeConsideration breakup, for the receipt figure. Amounts in IDR;
// PROVIDER_BENEFIT is a seller-funded discount, hence negative.
const breakup = [
  { type: 'ITEM', amount: 89000, sign: 1 },
  { type: 'DELIVERY', amount: 12000, sign: 1 },
  { type: 'TAX · PPN 11%', amount: 9790, sign: 1 },
  { type: 'PROVIDER_BENEFIT', amount: 10000, sign: -1 },
  { type: 'COD_FEE', amount: 2500, sign: 1 },
];
const breakupTotal = breakup.reduce((t, b) => t + b.sign * b.amount, 0);
const idr = (n) => 'Rp ' + n.toLocaleString('id-ID');
const barScale = 600 / breakupTotal; // total bar fills the track
---

