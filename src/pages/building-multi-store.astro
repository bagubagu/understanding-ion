            <text x="1052" y="312" text-anchor="end" font-family="JetBrains Mono" font-size="9.5" fill="#5e6f3c">amount − fee</text>

            <!-- Consumer → BAP (money in, off-network) -->
            <line x1="164" y1="192" x2="326" y2="192" stroke="#7a6f5e" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#pmG)"/>
            <text class="p-edge" x="245" y="180" text-anchor="middle" fill="#7a6f5e">authorize once · QRIS</text>
            <text class="p-edge" x="245" y="210" text-anchor="middle" fill="#7a6f5e" style="text-transform:none;">off-network</text>

            <!-- BAP → tenants (payout, off-network) -->
            <path d="M550 168 C 660 150, 700 80, 810 80" fill="none" stroke="#7a6f5e" stroke-width="1.5" stroke-dasharray="5 4" marker-end="url(#pmG)"/>
