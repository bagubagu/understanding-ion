---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Building a multi-store BPP + BAP · ION Network";
const description = "How to build two ION adapters: a multi-tenant BPP that serves many stores (each doing their own shipping) and a BAP that aggregates listings into one buyer experience.";
---

<BaseLayout title={title} description={description}>

  <nav class="top">
    <div class="inner">
      <div class="brand">building <span class="dot">●</span> bpp + bap</div>
      <div class="links">
        <a href="#picture"><span class="n">01</span>picture</a>
        <a href="#halves"><span class="n">02</span>two halves</a>
        <a href="#tenants"><span class="n">03</span>tenants</a>
        <a href="#shipping"><span class="n">04</span>shipping</a>
        <a href="#lifecycle"><span class="n">05</span>lifecycle</a>
        <a href="#routing"><span class="n">06</span>routing</a>
        <a href="#ops"><span class="n">07</span>ops</a>
        <span class="divider">|</span>
        <a class="cross" href="/">architecture</a>
        <a class="cross" href="/how-onix-works/">onix</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="page">
      <svg class="deco" viewBox="0 0 380 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <pattern id="grid-build" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M20 0H0V20" fill="none" stroke="#c6bba0" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="380" height="380" fill="url(#grid-build)"/>
        <rect x="110" y="110" width="160" height="160" fill="none" stroke="#c63d1a" stroke-width="0.8"/>
        <line x1="110" y1="150" x2="270" y2="150" stroke="#161513" stroke-width="0.5" stroke-dasharray="2 3"/>
        <line x1="110" y1="190" x2="270" y2="190" stroke="#161513" stroke-width="0.5" stroke-dasharray="2 3"/>
        <line x1="110" y1="230" x2="270" y2="230" stroke="#161513" stroke-width="0.5" stroke-dasharray="2 3"/>
        <circle cx="190" cy="170" r="3" fill="#c63d1a"/>
        <circle cx="190" cy="210" r="3" fill="#c63d1a"/>
        <text x="200" y="58" font-family="JetBrains Mono" font-size="9" fill="#7a6f5e">BPP / TENANTS · N</text>
      </svg>

      <div class="kicker smallcaps">A practical guide · Multi-store BPP + BAP</div>
      <h1>
        Build <span class="acc ital">two</span> adapters:<br/>
        one buyer app,<br/>
        one <span class="ital">multi-tenant</span> seller.
      </h1>
      <p class="lede">
        You're building a BPP that fronts <em>many stores</em> — each with its
        own inventory, its own prices, and its own shipping — and a BAP that
        aggregates listings (including yours) into a single buyer
        experience. The trick is that all your stores share <em>one</em>
        adapter process, and the shipping never leaves the Trade contract.
      </p>

      <div class="meta">
        <div class="item">
          <div class="v">2</div>
          <div class="l smallcaps">Adapters to build</div>
        </div>
        <div class="item">
          <div class="v">N</div>
          <div class="l smallcaps">Tenant stores</div>
        </div>
        <div class="item">
          <div class="v">1</div>
          <div class="l smallcaps">BPP process</div>
        </div>
        <div class="item">
          <div class="v">inline</div>
          <div class="l smallcaps">Shipping in Trade</div>
        </div>
      </div>
    </div>
  </header>


