  <script is:inline>
    (function () {
      const steps = [
        {
          title: "validateSign",
          label: "Step 01 · Identity check",
          body: "The handler reads the inbound Authorization header and the request body, asks the KeyManager for the sender's public key (looked up via the Registry plugin), and verifies the Ed25519 signature. If the signature is missing or invalid, the pipeline aborts immediately and the handler returns a signed NACK. On a bapTxnCaller the inbound caller is the buyer's own backend — the signature check confirms it has not been tampered with in flight.",
          hint: "plugin: SignValidator · failure: 401 NACK signed by ackSigner"
        },
        {
          title: "addRoute",
          label: "Step 02 · Routing decision",
          body: "The Router plugin walks the declared routing rules (by Beckn domain + version + endpoint) and chooses where this message goes next. For v1.x rules the match is keyed on domain; for v2.x rules routing is domain-agnostic. Targets can be a fixed URL, a dynamic bpp_uri pulled from the request context, the network gateway, or a message-queue topic for async dispatch.",
          hint: "plugin: Router · output: stepCtx.Route ready for sign + publish"
        },
        {
          title: "validateSchema",
          label: "Step 03 · Protocol conformance",
          body: "The SchemaValidator checks the message against the Beckn v2.0 OpenAPI spec — both the core protocol and, if extended validation is enabled, the domain-specific @context schema fetched from the URL embedded in the payload. The cached schema lifetime is configurable. A schema violation produces a 400 NACK with the failing path included in the error message.",
          hint: "plugin: SchemaValidator · spec: beckn.org/protocol-specifications-v2"
        },
        {
          title: "sign",
          label: "Step 04 · Outbound signing",
          body: "The Signer asks the KeyManager for this node's private key and produces an Ed25519 signature over the outbound body plus the standard Beckn signing string. The signature is attached as the Authorization header on the request that will leave the adapter. If a payloadStore is configured the raw header is also persisted for non-repudiation and countersignature validation later.",
          hint: "plugin: Signer + KeyManager · stored optionally by PayloadStore"
        },
        {
          title: "publish / forward",
          label: "Step 05 · Send",
          body: "Now the request actually leaves the adapter. If the route is a URL, the handler's wrapped http.Client posts the signed payload directly. If the route is a queue, the Publisher hands the message to RabbitMQ or Pub/Sub for asynchronous downstream processing. Either way the synchronous response — Beckn ACK or NACK — is itself signed before being returned to the caller, satisfying NFH-007 CON-004-02.",
          hint: "plugin: Publisher OR http forward · response: signed ACK/NACK"
        }
      ];

      const stepEls = document.querySelectorAll(".pipeline .step");
      const detail = document.getElementById("stepDetail");

      function setStep(i) {
        stepEls.forEach((el, idx) => {
          el.classList.toggle("active", idx === i);
        });
        const s = steps[i];
        detail.innerHTML =
          '<div class="lbl">' + s.label + '</div>' +
          '<div class="title">' + s.title + '</div>' +
          '<div>' + s.body + '</div>' +
          '<div class="hint">' + s.hint + '</div>';
      }
      stepEls.forEach((el, idx) => {
        el.addEventListener("click", function () { setStep(idx); });
        el.addEventListener("mouseenter", function () { setStep(idx); });
      });
      setStep(0);

      const io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add("in"); io.unobserve(e.target); }
        });
      }, { rootMargin: "0px 0px -60px 0px", threshold: 0.05 });

      document.querySelectorAll("section, figure, header.hero .lede, header.hero .meta")
        .forEach(function (el) { el.classList.add("reveal"); io.observe(el); });
    })();
  </script>
