// Not added to the doc-switcher in src/lib/docs.js — it's an unlisted route.
// Password protection is configured at the hosting layer (host-level), not here.
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
