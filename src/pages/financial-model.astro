const T={teal:"#234951",rust:"#c63d1a",moss:"#5e6f3c",amber:"#b07c2e",line:"#c6bba0",rustsoft:"#e6b8a8",muted:"#7a6f5e",ink:"#161513"};
function el(p,n,a){const e=document.createElementNS(NS,n);for(const k in a)e.setAttribute(k,a[k]);p.appendChild(e);return e;}
function txt(p,x,y,s,o={}){const e=el(p,"text",{x,y,"font-family":"JetBrains Mono, monospace","font-size":o.size||10,fill:o.fill||T.muted,"text-anchor":o.anchor||"middle"});e.textContent=s;return e;}
const M={l:46,r:14,t:14,b:26};

// orders ramp (millions) - area+line
(function(){
  const svg=document.getElementById("chOrders"),W=560,H=280,iw=W-M.l-M.r,ih=H-M.t-M.b;
  const vals=MONTHLY.map(m=>m[1]/1e6),max=Math.max(...vals);
  const x=i=>M.l+iw*i/(MONTHLY.length-1), y=v=>M.t+ih*(1-v/max);
  for(let g=0;g<=4;g++){const v=max*g/4,yy=y(v);el(svg,"line",{x1:M.l,x2:W-M.r,y1:yy,y2:yy,stroke:T.line,"stroke-width":.5,opacity:.6});txt(svg,M.l-6,yy+3,v.toFixed(0),{anchor:"end"});}
  let d="M "+x(0)+" "+y(0);MONTHLY.forEach((m,i)=>d+=" L "+x(i)+" "+y(vals[i]));
  el(svg,"path",{d:d+" L "+x(MONTHLY.length-1)+" "+y(0)+" Z",fill:T.teal,opacity:.14});
  let l="";MONTHLY.forEach((m,i)=>l+=(i?" L ":"M ")+x(i)+" "+y(vals[i]));
  el(svg,"path",{d:l,fill:"none",stroke:T.teal,"stroke-width":1.6});
  ["2026-09","2027-12","2030-12"].forEach(lbl=>{const i=MONTHLY.findIndex(m=>m[0]===lbl);el(svg,"circle",{cx:x(i),cy:y(vals[i]),r:3,fill:T.rust});txt(svg,x(i),H-8,lbl);});
  txt(svg,x(MONTHLY.findIndex(m=>m[0]==="2027-12")),y(20.66)-8,"20.7M",{fill:T.ink,size:9});
})();

// annual GMV log bars
(function(){
  const svg=document.getElementById("chGmv"),W=560,H=280,iw=W-M.l-M.r,ih=H-M.t-M.b;
  const lg=v=>Math.log10(v),min=0,max=4;//10^0..10^4
  const y=v=>M.t+ih*(1-(lg(v)-min)/(max-min));
  for(let p=0;p<=4;p++){const yy=M.t+ih*(1-p/4);el(svg,"line",{x1:M.l,x2:W-M.r,y1:yy,y2:yy,stroke:T.line,"stroke-width":.5,opacity:.6});txt(svg,M.l-6,yy+3,(p===0?"1":"1e"+p),{anchor:"end"});}
  const bw=iw/YEARS.length*0.55;
  YEARS.forEach((yr,i)=>{const cx=M.l+iw*(i+0.5)/YEARS.length,h=M.t+ih-y(GMV[i]);
    el(svg,"rect",{x:cx-bw/2,y:y(GMV[i]),width:bw,height:h,fill:T.rust,opacity:.85});
    txt(svg,cx,y(GMV[i])-6,GMV[i]>=1000?(GMV[i]/1000).toFixed(1)+"B":Math.round(GMV[i]),{fill:T.ink,size:9});
    txt(svg,cx,H-8,yr);});
})();

// revenue stacked + interest
(function(){
  const svg=document.getElementById("chRev"),W=560,H=300,iw=W-M.l-M.r,ih=H-M.t-M.b-6;
  const tot=YEARS.map((_,i)=>NET_FEE[i]+VAS[i]+COMP[i]+INT[i]),max=Math.max(...tot)*1.1;
  const y=v=>M.t+ih*(1-v/max),bw=iw/YEARS.length*0.5;
  for(let g=0;g<=4;g++){const v=max*g/4,yy=y(v);el(svg,"line",{x1:M.l,x2:W-M.r,y1:yy,y2:yy,stroke:T.line,"stroke-width":.5,opacity:.6});txt(svg,M.l-6,yy+3,v.toFixed(0),{anchor:"end"});}
  YEARS.forEach((yr,i)=>{const cx=M.l+iw*(i+0.5)/YEARS.length;let base=0;
    [[NET_FEE[i],T.teal],[VAS[i],T.moss],[COMP[i],T.amber],[INT[i],T.line]].forEach(([v,c])=>{if(v<=0)return;const h=ih*v/max;el(svg,"rect",{x:cx-bw/2,y:y(base+v),width:bw,height:h,fill:c,opacity:.9});base+=v;});
    txt(svg,cx,y(base)-6,Math.round(tot[i]),{fill:T.ink,size:9});txt(svg,cx,H-8,yr);});
})();

// take rate line + gmv area (dual)
(function(){
  const svg=document.getElementById("chTake"),W=560,H=300,iw=W-M.l-M.r,ih=H-M.t-M.b-6;
  const gmax=Math.max(...GMV)*1.1,tmax=1.6;
  const x=i=>M.l+iw*(i+0.5)/YEARS.length, yG=v=>M.t+ih*(1-v/gmax), yT=v=>M.t+ih*(1-v/tmax);
  for(let g=0;g<=4;g++){const yy=M.t+ih*g/4;el(svg,"line",{x1:M.l,x2:W-M.r,y1:yy,y2:yy,stroke:T.line,"stroke-width":.5,opacity:.5});}
  // gmv area
  let a="M "+x(0)+" "+(M.t+ih);YEARS.forEach((_,i)=>a+=" L "+x(i)+" "+yG(GMV[i]));a+=" L "+x(YEARS.length-1)+" "+(M.t+ih)+" Z";
  el(svg,"path",{d:a,fill:T.line,opacity:.3});
  // take line
  let l="";YEARS.forEach((_,i)=>l+=(i?" L ":"M ")+x(i)+" "+yT(TAKE[i]));
  el(svg,"path",{d:l,fill:"none",stroke:T.rust,"stroke-width":1.8});
  YEARS.forEach((yr,i)=>{el(svg,"circle",{cx:x(i),cy:yT(TAKE[i]),r:3,fill:T.rust});txt(svg,x(i),yT(TAKE[i])-8,TAKE[i].toFixed(3)+"%",{fill:T.rust,size:9});txt(svg,x(i),H-8,yr);});
  txt(svg,M.l-6,yT(1.6)+3,"1.6%",{anchor:"end",fill:T.rust});
  txt(svg,M.l-6,yT(0)+3,"0%",{anchor:"end",fill:T.rust});
})();

// profit grouped bars (neg/pos)
(function(){
  const svg=document.getElementById("chProfit"),W=560,H=300,iw=W-M.l-M.r,ih=H-M.t-M.b-6;
