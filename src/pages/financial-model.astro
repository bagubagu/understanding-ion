const GMV = [4.06,356.58,2114.13,2964.58,4037.77];
const NET_FEE=[0,4.9,27.0,33.4,39.4], VAS=[0,1,2,5,8], COMP=[0.5,1,3,3,5], INT=[0,0.45,3.47,3.40,3.49];
