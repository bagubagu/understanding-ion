<style is:inline>
:root{
  --paper:#f1ead8; --paper-deep:#e8dec5; --card:#f7f2e4;
  --ink:#161513; --ink-soft:#2a2622; --muted:#7a6f5e;
  --line:#c6bba0; --line-soft:#d8cfb4;
  --rust:#c63d1a; --rust-soft:#e6b8a8;
  --teal:#234951; --moss:#5e6f3c; --amber:#b07c2e;
  --max:1180px;
}
*,*::before,*::after{box-sizing:border-box;}
html{scroll-behavior:smooth;scroll-padding-top:72px;-webkit-text-size-adjust:100%;}
body{
  margin:0;background:var(--paper);color:var(--ink);
  font-family:"Newsreader",Georgia,serif;font-size:18px;line-height:1.65;font-weight:400;
  background-image:radial-gradient(rgba(120,100,60,.04) 1px,transparent 1px),radial-gradient(rgba(120,100,60,.025) 1px,transparent 1px);
  background-size:3px 3px,7px 7px;background-position:0 0,1px 2px;
}
h1,h2,h3,.display{font-family:"Fraunces","Times New Roman",serif;font-weight:350;letter-spacing:-.01em;color:var(--ink);}
.mono{font-family:"JetBrains Mono","SF Mono",Menlo,monospace;}
.smallcaps{font-family:"JetBrains Mono",monospace;text-transform:uppercase;letter-spacing:.16em;font-size:11px;font-weight:500;color:var(--muted);}
.ital{font-style:italic;}
.rust{color:var(--rust);} .teal{color:var(--teal);} .moss{color:var(--moss);} .amber{color:var(--amber);}
::selection{background:var(--rust);color:var(--paper);}
.page{max-width:var(--max);margin:0 auto;padding:0 32px;}
a{color:var(--teal);}

/* sticky nav */
nav.top{position:sticky;top:0;z-index:50;background:rgba(241,234,216,.92);backdrop-filter:saturate(140%) blur(6px);-webkit-backdrop-filter:saturate(140%) blur(6px);border-bottom:1px solid var(--line);}
nav.top .inner{max-width:var(--max);margin:0 auto;padding:11px 32px;display:flex;align-items:baseline;gap:22px;flex-wrap:wrap;}
nav.top .brand{font-family:"JetBrains Mono",monospace;font-size:13px;font-weight:600;letter-spacing:.04em;}
nav.top .brand .dot{color:var(--rust);}
nav.top .links{display:flex;gap:18px;flex-wrap:wrap;}
nav.top a{font-family:"JetBrains Mono",monospace;font-size:12px;letter-spacing:.04em;color:var(--muted);text-decoration:none;}
nav.top a:hover{color:var(--rust);}

/* hero */
header.hero{border-bottom:1px solid var(--line);}
header.hero .page{padding-top:54px;padding-bottom:46px;}
.kicker{margin-bottom:18px;}
h1{font-size:clamp(34px,5.4vw,60px);line-height:1.04;margin:0 0 22px;max-width:18ch;}
.lede{font-size:21px;line-height:1.55;max-width:62ch;color:var(--ink-soft);margin:0 0 30px;}
.lede em{font-style:italic;color:var(--rust);}
.verdict{display:flex;flex-wrap:wrap;gap:0;border:1px solid var(--line);background:var(--card);}
.verdict .v{flex:1 1 0;min-width:150px;padding:16px 20px;border-right:1px solid var(--line-soft);}
.verdict .v:last-child{border-right:none;}
.verdict .v .l{margin-bottom:6px;}
.verdict .v .b{font-size:16px;line-height:1.4;}
.tag-good{color:var(--moss);font-weight:600;} .tag-warn{color:var(--rust);font-weight:600;}

section{padding:56px 0;border-bottom:1px solid var(--line);}
.head{display:flex;align-items:baseline;gap:14px;margin-bottom:8px;}
.head .num{font-family:"JetBrains Mono",monospace;font-size:13px;color:var(--rust);font-weight:600;}
.head .tag{font-family:"JetBrains Mono",monospace;text-transform:uppercase;letter-spacing:.16em;font-size:11px;color:var(--muted);}
h2{font-size:clamp(26px,3.6vw,38px);line-height:1.1;margin:0 0 18px;max-width:22ch;}
.standfirst{font-size:19px;max-width:64ch;color:var(--ink-soft);margin:0 0 30px;}
p{max-width:68ch;}
.two{display:grid;grid-template-columns:1fr 1fr;gap:36px;align-items:start;}
@media(max-width:820px){.two{grid-template-columns:1fr;}}

/* metric cards */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(165px,1fr));gap:14px;margin:6px 0 8px;}
.mc{border:1px solid var(--line);background:var(--card);padding:16px 18px;}
.mc .l{margin-bottom:10px;}
.mc .big{font-family:"Fraunces",serif;font-size:30px;line-height:1;font-weight:350;}
.mc .sub{font-size:14px;color:var(--muted);margin-top:7px;}
.mc.neg .big{color:var(--rust);}
.mc.pos .big{color:var(--moss);}

/* table */
.tw{overflow-x:auto;margin:6px 0;border:1px solid var(--line);}
table{border-collapse:collapse;width:100%;font-size:15px;background:var(--card);min-width:560px;}
th,td{text-align:right;padding:10px 14px;border-bottom:1px solid var(--line-soft);}
th:first-child,td:first-child{text-align:left;}
thead th{font-family:"JetBrains Mono",monospace;font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);font-weight:600;background:var(--paper-deep);}
tbody tr:last-child td{border-bottom:none;}
td.num,th.num{font-family:"JetBrains Mono",monospace;font-variant-numeric:tabular-nums;}
tr.total td{font-weight:600;border-top:1px solid var(--line);}
.tneg{color:var(--rust);} .tpos{color:var(--moss);}
caption{caption-side:bottom;text-align:left;font-size:13px;color:var(--muted);padding:10px 4px;font-style:italic;}

/* charts */
figure{margin:0;}
.chart{border:1px solid var(--line);background:var(--card);padding:20px 20px 14px;}
.chart .ctitle{font-family:"JetBrains Mono",monospace;font-size:12px;letter-spacing:.04em;color:var(--ink-soft);font-weight:600;margin-bottom:2px;}
.chart .cnote{font-size:13px;color:var(--muted);margin-bottom:14px;}
.chart svg{width:100%;height:auto;display:block;}
.legend{display:flex;gap:16px;flex-wrap:wrap;margin-top:12px;font-family:"JetBrains Mono",monospace;font-size:11px;color:var(--muted);}
.legend span{display:inline-flex;align-items:center;gap:6px;}
.legend i{width:11px;height:11px;display:inline-block;border-radius:2px;}

/* callout */
.callout{border-left:3px solid var(--rust);background:var(--card);padding:18px 22px;margin:24px 0;}
.callout.good{border-left-color:var(--moss);}
.callout .ct{font-family:"JetBrains Mono",monospace;text-transform:uppercase;letter-spacing:.1em;font-size:11px;color:var(--rust);font-weight:600;margin-bottom:8px;}
.callout.good .ct{color:var(--moss);}
.callout p{margin:0;max-width:70ch;}
.pill{display:inline-block;font-family:"JetBrains Mono",monospace;font-size:10px;letter-spacing:.06em;text-transform:uppercase;padding:2px 8px;border-radius:10px;border:1px solid var(--line);color:var(--muted);background:var(--paper);}
.pill.crit{color:var(--rust);border-color:var(--rust-soft);}
.pill.fixed{color:var(--moss);border-color:#b9c79a;}

ul.clean{max-width:68ch;padding-left:20px;}
ul.clean li{margin-bottom:9px;}
footer{padding:40px 0 64px;color:var(--muted);font-size:14px;}
footer .page>div{max-width:70ch;}
.src{font-family:"JetBrains Mono",monospace;font-size:12px;}
</style>
</head>
