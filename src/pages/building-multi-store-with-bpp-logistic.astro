---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Building a multi-store BPP + BAP with a Logistics BPP · ION Network";
const description = "How the marketplace BAP arranges carriage through a separate Logistics BPP (JNE): per-store Trade contracts each linked to their own Logistics contract by linkedContractId, with BAP-collected escrow paying both the stores and the carrier.";
---

<BaseLayout title={title} description={description}>

  <nav class="top">
    <div class="inner">
      <div class="brand">building <span class="dot">●</span> bpp + bap + 3pl</div>
      <div class="links">
        <a href="#picture"><span class="n">01</span>picture</a>
        <a href="#cast"><span class="n">02</span>cast</a>
        <a href="#tenants"><span class="n">03</span>tenants</a>
        <a href="#logistics"><span class="n">04</span>logistics</a>
        <a href="#payment"><span class="n">05</span>payment</a>
        <a href="#lifecycle"><span class="n">06</span>lifecycle</a>
        <a href="#routing"><span class="n">07</span>routing</a>
        <a href="#ops"><span class="n">08</span>ops</a>
        <span class="divider">|</span>
        <a class="cross" href="/building-multi-store/">in-house</a>
        <a class="cross" href="/transaction/">trade × logistics</a>
        <a class="cross" href="/how-onix-works/">onix</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="page">
      <svg class="deco" viewBox="0 0 380 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <pattern id="grid-3pl" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M20 0H0V20" fill="none" stroke="#c6bba0" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="380" height="380" fill="url(#grid-3pl)"/>
        <rect x="110" y="90" width="160" height="90" fill="none" stroke="#c63d1a" stroke-width="0.8"/>
        <rect x="110" y="210" width="160" height="90" fill="none" stroke="#234951" stroke-width="0.8"/>
        <line x1="190" y1="180" x2="190" y2="210" stroke="#161513" stroke-width="0.5" stroke-dasharray="2 3"/>
        <circle cx="190" cy="180" r="3" fill="#c63d1a"/>
        <circle cx="190" cy="210" r="3" fill="#234951"/>
        <text x="200" y="58" font-family="JetBrains Mono" font-size="9" fill="#7a6f5e">TRADE × LOGISTICS · LINKED</text>
      </svg>

      <div class="kicker smallcaps">A practical guide · Multi-store + Logistics BPP</div>
      <h1>
        Ship through a <span class="acc ital">Logistics BPP</span>,<br/>
        not your own van.
      </h1>
      <p class="lede">
        Same multi-tenant seller BPP, same aggregating BAP as the
        <a href="/building-multi-store/">in-house build</a> — but now no
        store owns a delivery fleet. Your BAP wears a <em>second hat</em>:
        a Logistics BAP that books a carrier (JNE) over the network. Each
        store's Trade contract earns its own Logistics contract, joined by
        <em>linkedContractId</em>, and your marketplace escrow pays both
        the store and the carrier.
      </p>

      <div class="meta">
        <div class="item">
          <div class="v">N</div>
          <div class="l smallcaps">Tenant stores</div>
        </div>
        <div class="item">
          <div class="v">2</div>
          <div class="l smallcaps">Contracts per order</div>
        </div>
        <div class="item">
          <div class="v">JNE</div>
          <div class="l smallcaps">Logistics BPP</div>
        </div>
        <div class="item">
          <div class="v">BAP</div>
          <div class="l smallcaps">Books & pays</div>
        </div>
      </div>
    </div>
  </header>


