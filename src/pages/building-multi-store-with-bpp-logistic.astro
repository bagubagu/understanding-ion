            <text class="lk-ttl" x="100" y="178" text-anchor="middle">Store A</text>
            <text class="lk-sub" x="100" y="196" text-anchor="middle">merchant</text>

            <rect x="490" y="150" width="120" height="60" fill="#e8dec5" stroke="#c63d1a" stroke-width="1.2"/>
