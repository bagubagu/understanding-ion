            </style>

            <text x="20" y="34" font-family="Fraunces" font-style="italic" font-size="16" fill="#161513">fig.02</text>
            <text x="20" y="52" font-family="JetBrains Mono" font-size="10" fill="#7a6f5e">two linked contracts · per store</text>

