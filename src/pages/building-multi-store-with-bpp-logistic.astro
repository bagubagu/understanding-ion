              .py-sub  { font: italic 400 11.5px "Newsreader", serif; fill: #7a6f5e; }
              .py-edge { font: 500 9.5px "JetBrains Mono", monospace; letter-spacing: 1px; text-transform: uppercase; }
            </style>

            <text x="20" y="34" font-family="Fraunces" font-style="italic" font-size="16" fill="#161513">fig.03</text>
            <text x="20" y="52" font-family="JetBrains Mono" font-size="10" fill="#7a6f5e">escrow · pays goods + freight</text>

            <!-- Consumer -->
            <rect x="24" y="180" width="140" height="84" fill="none" stroke="#161513" stroke-width="1.2"/>
            <rect x="24" y="180" width="140" height="20" fill="#161513"/>
            <text class="py-lbl" x="94" y="194" text-anchor="middle">CONSUMER</text>
            <text class="py-ttl" x="94" y="226" text-anchor="middle">Andi</text>
            <text class="py-sub" x="94" y="246" text-anchor="middle">pays once</text>

            <!-- BAP escrow -->
            <rect x="330" y="146" width="220" height="152" fill="#e8dec5" stroke="#c63d1a" stroke-width="1.4"/>
            <rect x="330" y="146" width="220" height="20" fill="#c63d1a"/>
