            <g>
              <rect x="350" y="232" width="540" height="116" fill="#e8dec5" stroke="#c6bba0"/>
              <text class="box-title" x="620" y="266" text-anchor="middle">ION Network</text>
              <text class="box-sub"   x="620" y="288" text-anchor="middle"><tspan font-family="JetBrains Mono" font-size="12.5">ion.yaml</tspan> — network profile</text>
              <line x1="380" y1="300" x2="860" y2="300" stroke="#c6bba0"/>
              <rect x="380" y="312" width="220" height="26" fill="#f1ead8" stroke="#c6bba0"/>
              <text class="pill" x="490" y="329" text-anchor="middle">Policy Registry</text>
              <rect x="640" y="312" width="220" height="26" fill="#f1ead8" stroke="#c6bba0"/>
              <text class="pill" x="750" y="329" text-anchor="middle">Error Registry</text>
            </g>

            <line x1="620" y1="348" x2="620" y2="380" stroke="#c6bba0" stroke-width="1.2"/>
            <line x1="180" y1="380" x2="1060" y2="380" stroke="#c6bba0" stroke-width="1.2"/>
            <line x1="180" y1="380" x2="180" y2="416" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>
            <line x1="620" y1="380" x2="620" y2="416" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>
            <line x1="1060" y1="380" x2="1060" y2="416" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>

            <g>
              <rect x="60" y="424" width="240" height="92" fill="#e8dec5" stroke="#c6bba0"/>
              <text class="box-title" x="180" y="462" text-anchor="middle">ION Registry</text>
              <text class="box-sub"   x="180" y="486" text-anchor="middle">on DeDi</text>
            </g>
            <g>
              <rect x="500" y="424" width="240" height="92" fill="#e8dec5" stroke="#c6bba0"/>
              <text class="box-title" x="620" y="462" text-anchor="middle">Catalogue Service</text>
              <text class="box-sub"   x="620" y="486" text-anchor="middle">Beckn Fabric</text>
            </g>
            <g>
              <rect x="940" y="424" width="240" height="92" fill="#e8dec5" stroke="#c6bba0"/>
              <text class="box-title" x="1060" y="462" text-anchor="middle">Discover Service</text>
              <text class="box-sub"   x="1060" y="486" text-anchor="middle">CDS</text>
            </g>

            <text class="edge-label" x="180" y="548" text-anchor="middle">registers</text>
            <text class="edge-label" x="620" y="548" text-anchor="middle">publishes</text>
            <text class="edge-label" x="1060" y="548" text-anchor="middle">queries · subscribes</text>

            <line x1="180"  y1="554" x2="180"  y2="612" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>
            <line x1="620"  y1="554" x2="620"  y2="612" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>
            <line x1="1060" y1="554" x2="1060" y2="612" stroke="#c6bba0" stroke-width="1.2" marker-end="url(#arrAr)"/>

            <g>
              <rect x="40" y="620" width="280" height="116" fill="#e8dec5" stroke="#c63d1a" stroke-width="1.2"/>
              <rect x="40" y="620" width="6" height="116" fill="#c63d1a"/>
              <text class="box-title" x="180" y="658" text-anchor="middle">BAP</text>
              <text class="box-sub"   x="180" y="682" text-anchor="middle">Buyer apps</text>
              <text class="box-detail" x="180" y="708" text-anchor="middle">Pasar Sapa · Tokopedia · Shopee</text>
            </g>
            <g>
              <rect x="480" y="620" width="280" height="116" fill="#e8dec5" stroke="#c63d1a" stroke-width="1.2"/>
