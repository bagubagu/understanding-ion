                <path d="M0,0 L10,5 L0,10 z" fill="#c6bba0"/>
              </marker>
              <marker id="arrArAcc" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
                <path d="M0,0 L10,5 L0,10 z" fill="#c63d1a"/>
              </marker>
            </defs>

