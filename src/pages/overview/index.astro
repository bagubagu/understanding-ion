---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "ION Network · Architecture";
const description = "A reference architecture for the ION Network — governance, network profile, core services, and Beckn participant interactions.";
---

<BaseLayout title={title} description={description}>

  <nav class="top">
    <div class="inner">
      <div class="brand">the <span class="dot">●</span> ion network</div>
      <div class="links">
        <a href="#picture"><span class="n">01</span>picture</a>
        <a href="#governance"><span class="n">02</span>governance</a>
        <a href="#profile"><span class="n">03</span>profile</a>
        <a href="#services"><span class="n">04</span>services</a>
        <a href="#participants"><span class="n">05</span>participants</a>
        <a href="#protocol"><span class="n">06</span>protocol</a>
        <a href="/overview/transaction/">transaction</a>
        <a href="/overview/transaction-with-payment/">+ payment</a>
        <a href="/overview/how-onix-works/">onix</a>
      </div>
    </div>
  </nav>

  <header class="hero">
    <div class="page">
      <svg class="deco" viewBox="0 0 380 380" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <defs>
          <pattern id="grid-arch" width="20" height="20" patternUnits="userSpaceOnUse">
            <path d="M20 0H0V20" fill="none" stroke="#c6bba0" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="380" height="380" fill="url(#grid-arch)"/>
        <circle cx="190" cy="190" r="150" fill="none" stroke="#c63d1a" stroke-width="0.8"/>
        <circle cx="190" cy="190" r="110" fill="none" stroke="#234951" stroke-width="0.6"/>
        <circle cx="190" cy="190" r="70"  fill="none" stroke="#161513" stroke-width="0.6"/>
        <circle cx="190" cy="190" r="3"   fill="#c63d1a"/>
        <line x1="0" y1="190" x2="380" y2="190" stroke="#161513" stroke-width="0.4" stroke-dasharray="2 4"/>
        <line x1="190" y1="0" x2="190" y2="380" stroke="#161513" stroke-width="0.4" stroke-dasharray="2 4"/>
        <text x="200" y="58" font-family="JetBrains Mono" font-size="9" fill="#7a6f5e">ION / ARCH</text>
      </svg>

      <div class="kicker smallcaps">A reference architecture · Beckn protocol v2.0</div>
      <h1>
        An <span class="acc ital">open commerce</span><br/>
        network, ratified by a <span class="ital">council</span>.
      </h1>
      <p class="lede">
        ION layers governance, a network profile, and three core services on top of
        the Beckn protocol — connecting <em>buyer apps, providers, and consumers</em>
        across Indonesian commerce.
      </p>

      <div class="meta">
        <div class="item">
          <div class="v">5</div>
          <div class="l smallcaps">Layers</div>
        </div>
        <div class="item">
          <div class="v">3</div>
          <div class="l smallcaps">Core services</div>
        </div>
        <div class="item">
          <div class="v">BAP ↔ BPP</div>
          <div class="l smallcaps">Participant edge</div>
        </div>
        <div class="item">
          <div class="v">v2.0</div>
          <div class="l smallcaps">Beckn protocol</div>
        </div>
      </div>
    </div>
  </header>


  <section id="picture">
    <div class="page">

      <div class="head">
        <span class="num">01</span>
        <span class="tag">The picture</span>
      </div>
      <h2>Five layers, <span class="ital">one trunk.</span></h2>
      <p class="standfirst">
        The Council ratifies the network. The network profile codifies what's
        allowed. Three core services keep the directory, catalogue, and
        discovery live. Participants — buyer and provider platforms — speak
        the Beckn protocol across the shared rail. The consumer is the only
        layer that doesn't run code.
      </p>

      <figure>
        <div class="frame">
          <svg viewBox="0 0 1240 920" xmlns="http://www.w3.org/2000/svg" role="img" aria-labelledby="arch-title arch-desc">
