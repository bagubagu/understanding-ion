              .edge-label.accent { fill: #c63d1a; }
              .pill { font: 500 12px "JetBrains Mono", monospace; fill: #161513; letter-spacing: 0.5px; }
            </style>

            <text class="tier-label" x="40" y="60">L1 · Governance</text>
            <text class="tier-label" x="40" y="220">L2 · Network profile</text>
            <text class="tier-label" x="40" y="400">L3 · Core services</text>
            <text class="tier-label" x="40" y="600">L4 · Participants</text>
            <text class="tier-label" x="40" y="860">L5 · End user</text>

            <g>
              <rect x="490" y="76" width="260" height="78" fill="#e8dec5" stroke="#c63d1a" stroke-width="1.2"/>
              <rect x="490" y="76" width="6" height="78" fill="#c63d1a"/>
