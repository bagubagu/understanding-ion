              .box-title  { font: italic 350 22px "Fraunces", serif; fill: #161513; }
              .box-sub    { font: italic 400 13.5px "Newsreader", serif; fill: #2a2622; }
              .box-detail { font: 400 12.5px "Newsreader", serif; fill: #7a6f5e; }
